{
  "name": "agentshop-desktop",
  "private": true,
  "version": "0.1.0",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "npm run dev:vite",
    "dev:vite": "vite",
    "build:renderer": "vite build",
    "build": "npm run build:renderer",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "electron": "^28.0.0",
    "phaser": "^3.90.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.0.0",
    "react-router-dom": "^6.22.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.agentshop.desktop",
    "productName": "AgentShop",
    "files": [
      "dist/**",
      "src/main/**",
      "public/assets/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
